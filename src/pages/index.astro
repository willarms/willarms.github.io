---
// src/pages/index.astro
// This is your homepage. It replaces index.html.
// Edit content directly in the HTML below.
// To add/edit projects, update src/data/projects.ts — not this file.

import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { allProjects } from "../data/projects";

// Show featured projects first, then the rest
const featured = allProjects.filter((p) => p.featured);
const others   = allProjects.filter((p) => !p.featured);
---

<BaseLayout title="Will Armsworthy">

  <!-- ── HERO ──────────────────────────────────────────────── -->
  <section id="home" class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow">CS @ Notre Dame</p>
      <h1>Will Armsworthy</h1>
      <!-- UPDATE: your tagline -->
      <p class="hero-sub">I like data, hard problems, and building things that work.</p>
      <div class="hero-links">
        <a href="#projects" class="btn-primary">See my work</a>
        <a href="#contact" class="btn-ghost">Get in touch</a>
      </div>
    </div>
  </section>

  <!-- ── ABOUT ─────────────────────────────────────────────── -->
  <section id="about">
    <div class="section-inner">
      <h2>About Me</h2>
      <div class="about-content">
        <!-- UPDATE: expand this as much as you want -->
        <p>
          Hi! I'm Will, a senior studying Computer Science at the University of Notre Dame.
          I'm interested in data engineering, sports analytics, and building tools that turn
          messy data into something useful. When I'm not in class I'm usually working on a
          side project or trying to find edges in sports markets.
        </p>
        <!-- Add more paragraphs, a skills list, coursework, etc. here -->
      </div>
    </div>
  </section>

  <!-- ── PROJECTS ──────────────────────────────────────────── -->
  <section id="projects">
    <div class="section-inner">
      <h2>Projects</h2>

      {featured.length > 0 && (
        <>
          <h3 class="section-sub">Featured</h3>
          <div class="projects-grid">
            {featured.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
        </>
      )}

      {others.length > 0 && (
        <>
          <h3 class="section-sub" style="margin-top: 2.5rem;">Other Projects</h3>
          <div class="projects-grid">
            {others.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
        </>
      )}
    </div>
  </section>

  <!-- ── CONTACT ────────────────────────────────────────────── -->
  <section id="contact">
    <div class="section-inner">
      <h2>Contact</h2>
      <div class="contact-links">
        <!-- UPDATE: remove school email after graduation -->
        <div class="contact-item">
          <span class="contact-label">School</span>
          <a href="mailto:warmswor@nd.edu">warmswor@nd.edu</a>
        </div>
        <div class="contact-item">
          <span class="contact-label">Personal</span>
          <a href="mailto:armsworthy61@gmail.com">armsworthy61@gmail.com</a>
        </div>
        <div class="contact-item">
          <span class="contact-label">LinkedIn</span>
          <a href="https://www.linkedin.com/in/william-armsworthy-379136259" target="_blank" rel="noopener">
            william-armsworthy
          </a>
        </div>
        <div class="contact-item">
          <span class="contact-label">GitHub</span>
          <a href="https://github.com/willarms" target="_blank" rel="noopener">
            willarms
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── HERO ─────────────────────────────────────────────────── */
  .hero {
    min-height: 70vh;
    display: flex;
    align-items: center;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .hero-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--color-muted);
    max-width: 480px;
    margin-bottom: 2rem;
  }

  .hero-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
    padding: 0.65rem 1.4rem;
    border-radius: var(--radius);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.15s;
  }

  .btn-primary:hover { background: var(--color-accent-hover); color: #fff; }

  .btn-ghost {
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: 0.65rem 1.4rem;
    border-radius: var(--radius);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: border-color 0.15s;
  }

  .btn-ghost:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── SECTIONS ─────────────────────────────────────────────── */
  section {
    padding: 5rem 0;
  }

  section:nth-child(even) {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-inner h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .section-sub {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  /* ── ABOUT ────────────────────────────────────────────────── */
  .about-content {
    max-width: 640px;
    color: var(--color-muted);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── PROJECTS GRID ────────────────────────────────────────── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* ── CONTACT ──────────────────────────────────────────────── */
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 400px;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .contact-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    min-width: 72px;
  }

  .contact-item a {
    font-size: 0.95rem;
    text-decoration: none;
    color: var(--color-text);
  }

  .contact-item a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .hero-inner { padding: 3rem 1rem; }
    .section-inner { padding: 0 1rem; }
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
